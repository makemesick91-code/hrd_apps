generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  password       String
  role           Role           @default(EMPLOYEE)
  isActive       Boolean        @default(true)
  isVerified     Boolean        @default(false)
  otpCode        String?
  otpExpiry      DateTime?
  lastLogin      DateTime?
  loginAttempts  Int            @default(0)
  lockedUntil    DateTime?
  refreshToken   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  auditLogs      AuditLog[]
  employee       Employee?
  loginHistories LoginHistory[]
  notifications  Notification[]

  @@map("users")
}

model Company {
  id             String           @id @default(cuid())
  name           String
  legalName      String?
  logo           String?
  email          String?
  phone          String?
  address        String?
  city           String?
  province       String?
  country        String           @default("Indonesia")
  postalCode     String?
  website        String?
  npwp           String?
  industry       String?
  primaryColor   String           @default("#1E3A8A")
  secondaryColor String           @default("#F4B400")
  description    String?
  vision         String?
  mission        String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  announcements  Announcement[]
  branches       Branch[]
  settings       CompanySetting[]

  @@map("companies")
}

model Branch {
  id        String     @id @default(cuid())
  companyId String
  name      String
  code      String
  address   String?
  city      String?
  phone     String?
  isMain    Boolean    @default(false)
  latitude  Float?
  longitude Float?
  radius    Int?       @default(100)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  company   Company    @relation(fields: [companyId], references: [id])
  employees Employee[]

  @@map("branches")
}

model Department {
  id          String       @id @default(cuid())
  name        String
  code        String       @unique
  description String?
  headId      String?
  parentId    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  parent      Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DepartmentHierarchy")
  employees   Employee[]
  positions   Position[]

  @@map("departments")
}

model Position {
  id           String        @id @default(cuid())
  departmentId String
  name         String
  code         String        @unique
  description  String?
  level        Int           @default(1)
  minSalary    Float?
  maxSalary    Float?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  employees    Employee[]
  department   Department    @relation(fields: [departmentId], references: [id])
  recruitments Recruitment[]

  @@map("positions")
}

model Employee {
  id                  String              @id @default(cuid())
  userId              String              @unique
  employeeId          String              @unique
  branchId            String?
  departmentId        String?
  positionId          String?
  managerId           String?
  firstName           String
  lastName            String
  fullName            String
  nickname            String?
  gender              Gender
  birthDate           DateTime?
  birthPlace          String?
  nationality         String?             @default("WNI")
  religion            String?
  maritalStatus       String?
  bloodType           String?
  photo               String?
  email               String              @unique
  phone               String?
  phoneEmergency      String?
  emergencyContact    String?
  address             String?
  city                String?
  province            String?
  postalCode          String?
  nik                 String?             @unique
  npwp                String?
  bpjsKesehatan       String?
  bpjsKetenagakerjaan String?
  joinDate            DateTime
  contractType        ContractType        @default(PERMANENT)
  contractStart       DateTime?
  contractEnd         DateTime?
  employmentStatus    EmploymentStatus    @default(ACTIVE)
  probationEnd        DateTime?
  basicSalary         Float               @default(0)
  allowances          Float               @default(0)
  bankName            String?
  bankAccount         String?
  bankAccountName     String?
  education           String?
  university          String?
  major               String?
  skills              String[]
  bio                 String?
  faceDescriptor      String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  announcements       AnnouncementRead[]
  attendance          Attendance[]
  documents           Document[]
  branch              Branch?             @relation(fields: [branchId], references: [id])
  department          Department?         @relation(fields: [departmentId], references: [id])
  manager             Employee?           @relation("EmployeeManager", fields: [managerId], references: [id])
  subordinates        Employee[]          @relation("EmployeeManager")
  position            Position?           @relation(fields: [positionId], references: [id])
  user                User                @relation(fields: [userId], references: [id])
  kpis                KPI[]
  leaveBalances       LeaveBalance[]
  leaveRequests       LeaveRequest[]
  notifications       Notification[]      @relation("EmployeeNotification")
  payrolls            Payroll[]
  performances        PerformanceReview[]
  workHistories       WorkHistory[]

  @@map("employees")
}

model WorkHistory {
  id          String    @id @default(cuid())
  employeeId  String
  company     String
  position    String
  startDate   DateTime
  endDate     DateTime?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  employee    Employee  @relation(fields: [employeeId], references: [id])

  @@map("work_histories")
}

model Shift {
  id                  String       @id @default(cuid())
  name                String
  code                String       @unique
  startTime           String
  endTime             String
  breakStart          String?
  breakEnd            String?
  workDays            Int[]
  isActive            Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  timezone            String       @default("Asia/Makassar")
  toleranceMinutes    Int          @default(15)
  color               String       @default("#1E3A8A")
  earlyLeaveTolerance Int          @default(0)
  requireCheckIn      Boolean      @default(true)
  requireCheckOut     Boolean      @default(true)
  scanInEnd           String?
  scanInStart         String?
  scanOutEnd          String?
  scanOutStart        String?
  workDaysCount       Int          @default(1)
  workMinutesCount    Int          @default(0)
  attendance          Attendance[]

  @@map("shifts")
}

model Attendance {
  id                String           @id @default(cuid())
  employeeId        String
  shiftId           String?
  date              DateTime         @db.Date
  checkIn           DateTime?
  checkOut          DateTime?
  checkInLat        Float?
  checkInLng        Float?
  checkOutLat       Float?
  checkOutLng       Float?
  method            AttendanceMethod @default(MANUAL)
  status            AttendanceStatus @default(PRESENT)
  workHours         Float?
  overtimeHours     Float?
  lateMinutes       Int?
  earlyLeaveMinutes Int?
  notes             String?
  photoIn           String?
  photoOut          String?
  approvedBy        String?
  approvedAt        DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  employee          Employee         @relation(fields: [employeeId], references: [id])
  shift             Shift?           @relation(fields: [shiftId], references: [id])

  @@unique([employeeId, date])
  @@map("attendance")
}

model Payroll {
  id                  String             @id @default(cuid())
  employeeId          String
  period              String
  year                Int
  month               Int
  basicSalary         Float
  allowances          Float              @default(0)
  overtime            Float              @default(0)
  bonus               Float              @default(0)
  deductions          Float              @default(0)
  bpjsKesehatan       Float              @default(0)
  bpjsKetenagakerjaan Float              @default(0)
  pph21               Float              @default(0)
  netSalary           Float
  workDays            Int                @default(0)
  presentDays         Int                @default(0)
  absentDays          Int                @default(0)
  overtimeHours       Float              @default(0)
  status              PayrollStatus      @default(DRAFT)
  approvedBy          String?
  approvedAt          DateTime?
  paidAt              DateTime?
  notes               String?
  slipUrl             String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  components          PayrollComponent[]
  employee            Employee           @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, year, month])
  @@map("payrolls")
}

model PayrollComponent {
  id        String   @id @default(cuid())
  payrollId String
  name      String
  type      String
  amount    Float
  note      String?
  createdAt DateTime @default(now())
  payroll   Payroll  @relation(fields: [payrollId], references: [id])

  @@map("payroll_components")
}

model LeavePolicy {
  id            String    @id @default(cuid())
  leaveType     LeaveType @unique
  daysPerYear   Int
  canCarryOver  Boolean   @default(false)
  maxCarryOver  Int       @default(0)
  minDaysNotice Int       @default(0)
  description   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("leave_policies")
}

model LeaveBalance {
  id         String    @id @default(cuid())
  employeeId String
  leaveType  LeaveType
  year       Int
  balance    Int
  used       Int       @default(0)
  remaining  Int
  carried    Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  employee   Employee  @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, leaveType, year])
  @@map("leave_balances")
}

model LeaveRequest {
  id             String      @id @default(cuid())
  employeeId     String
  leaveType      LeaveType
  startDate      DateTime    @db.Date
  endDate        DateTime    @db.Date
  totalDays      Int
  reason         String
  status         LeaveStatus @default(PENDING)
  approvedBy     String?
  approvedAt     DateTime?
  rejectedReason String?
  attachment     String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  employee       Employee    @relation(fields: [employeeId], references: [id])

  @@map("leave_requests")
}

model Recruitment {
  id           String            @id @default(cuid())
  positionId   String?
  title        String
  description  String?
  requirements String?
  benefits     String?
  salaryMin    Float?
  salaryMax    Float?
  location     String?
  type         ContractType      @default(PERMANENT)
  status       RecruitmentStatus @default(OPEN)
  deadline     DateTime?
  quota        Int               @default(1)
  filled       Int               @default(0)
  isPublic     Boolean           @default(true)
  postedBy     String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  applicants   Applicant[]
  position     Position?         @relation(fields: [positionId], references: [id])

  @@map("recruitments")
}

model Applicant {
  id             String          @id @default(cuid())
  recruitmentId  String
  firstName      String
  lastName       String
  email          String
  phone          String?
  address        String?
  education      String?
  experience     String?
  cvUrl          String?
  portfolioUrl   String?
  linkedinUrl    String?
  status         ApplicantStatus @default(APPLIED)
  expectedSalary Float?
  notes          String?
  rating         Int?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  recruitment    Recruitment     @relation(fields: [recruitmentId], references: [id])
  interviews     Interview[]

  @@map("applicants")
}

model Interview {
  id           String    @id @default(cuid())
  applicantId  String
  type         String
  scheduledAt  DateTime
  location     String?
  meetingLink  String?
  interviewers String[]
  notes        String?
  result       String?
  rating       Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  applicant    Applicant @relation(fields: [applicantId], references: [id])

  @@map("interviews")
}

model KPI {
  id          String   @id @default(cuid())
  employeeId  String
  title       String
  description String?
  target      Float
  actual      Float    @default(0)
  weight      Float    @default(1)
  unit        String?
  period      String
  year        Int
  month       Int?
  achieved    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee @relation(fields: [employeeId], references: [id])

  @@map("kpis")
}

model PerformanceReview {
  id             String            @id @default(cuid())
  employeeId     String
  reviewerId     String
  period         String
  year           Int
  quarter        Int?
  rating         PerformanceRating
  score          Float
  attendance     Float?
  productivity   Float?
  teamwork       Float?
  leadership     Float?
  innovation     Float?
  strengths      String?
  improvements   String?
  goals          String?
  notes          String?
  isAcknowledged Boolean           @default(false)
  acknowledgedAt DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  employee       Employee          @relation(fields: [employeeId], references: [id])

  @@map("performance_reviews")
}

model Document {
  id          String           @id @default(cuid())
  employeeId  String?
  category    DocumentCategory
  name        String
  description String?
  fileUrl     String
  fileType    String?
  fileSize    Int?
  isPublic    Boolean          @default(false)
  expiryDate  DateTime?
  uploadedBy  String?
  tags        String[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  employee    Employee?        @relation(fields: [employeeId], references: [id])

  @@map("documents")
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  employeeId String?
  type       NotificationType
  title      String
  message    String
  data       Json?
  isRead     Boolean          @default(false)
  readAt     DateTime?
  link       String?
  createdAt  DateTime         @default(now())
  employee   Employee?        @relation("EmployeeNotification", fields: [employeeId], references: [id])
  user       User             @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model Announcement {
  id          String             @id @default(cuid())
  companyId   String
  title       String
  content     String
  imageUrl    String?
  isPinned    Boolean            @default(false)
  isPublic    Boolean            @default(true)
  publishedAt DateTime?
  expiresAt   DateTime?
  postedBy    String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  reads       AnnouncementRead[]
  company     Company            @relation(fields: [companyId], references: [id])

  @@map("announcements")
}

model AnnouncementRead {
  id             String       @id @default(cuid())
  announcementId String
  employeeId     String
  readAt         DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id])
  employee       Employee     @relation(fields: [employeeId], references: [id])

  @@unique([announcementId, employeeId])
  @@map("announcement_reads")
}

model CompanySetting {
  id        String   @id @default(cuid())
  companyId String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId, key])
  @@map("company_settings")
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String
  action    AuditAction
  entity    String
  entityId  String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  ipAddress String?
  userAgent String?
  location  String?
  success   Boolean
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@map("login_histories")
}

model Holiday {
  id          String   @id @default(cuid())
  name        String
  date        DateTime @db.Date
  description String?
  isNational  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("holidays")
}

enum Role {
  SUPER_ADMIN
  HRD
  MANAGER
  EMPLOYEE
}

enum Gender {
  MALE
  FEMALE
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
  TERMINATED
  RESIGNED
  ON_LEAVE
  PROBATION
}

enum ContractType {
  PERMANENT
  CONTRACT
  INTERNSHIP
  FREELANCE
  PART_TIME
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  SICK
  PERMISSION
  WFH
  EARLY_LEAVE
  HOLIDAY
}

enum AttendanceMethod {
  MANUAL
  QR_CODE
  GPS
  FACE
  FINGERPRINT
}

enum LeaveType {
  ANNUAL
  SICK
  EMERGENCY
  MATERNITY
  PATERNITY
  UNPAID
  PERMISSION
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PayrollStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PAID
  CANCELLED
}

enum RecruitmentStatus {
  OPEN
  CLOSED
  ON_HOLD
  CANCELLED
}

enum ApplicantStatus {
  APPLIED
  SCREENING
  INTERVIEW_1
  INTERVIEW_2
  PSYCHOTEST
  OFFERING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum NotificationType {
  SYSTEM
  ATTENDANCE
  PAYROLL
  LEAVE
  RECRUITMENT
  PERFORMANCE
  ANNOUNCEMENT
  CONTRACT
  BIRTHDAY
}

enum DocumentCategory {
  CONTRACT
  CERTIFICATE
  KTP
  NPWP
  BPJS
  IJAZAH
  TRANSCRIPT
  PHOTO
  OTHER
}

enum PerformanceRating {
  EXCELLENT
  GOOD
  SATISFACTORY
  NEEDS_IMPROVEMENT
  UNSATISFACTORY
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  APPROVE
  REJECT
}
